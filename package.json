{
  "name": "@rabbitai/agent-browser-sdk",
  "version": "1.0.0",
  "description": "Agent Browser SDK for RabbitAI - connect to agent-browser agent and execute browser commands",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "rabbitai",
    "agent-browser",
    "browser-automation",
    "sdk"
  ],
  "license": "MIT"
}
